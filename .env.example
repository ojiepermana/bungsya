# ─────────────────────────────────────────────────────────────────────────────
# Template for the shared root .env. Copy to `.env` and adjust:
#     cp .env.example .env
#
# Bun auto-loads .env for every `bun` command, so Elysia reads it directly.
# Angular can't read .env in the browser, so the frontend keys below are baked
# in at build time by scripts/generate-env.ts (run before dev:app / build:app).
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development

# ── Backend (Elysia) — server-only, never shipped to the browser ─────────────
# Uses API_PORT (not PORT): `ng serve` hijacks its port from PORT, so a bare
# PORT here would push the Angular dev-server onto the API port. Keep them apart.
API_PORT=3000
# Directory of the built Angular SPA the API serves in production (default dist/public).
# PUBLIC_DIR=dist/public

# ── Frontend (Angular) — baked into the browser bundle ───────────────────────
# Only keys allowlisted in scripts/generate-env.ts (PUBLIC_KEYS) reach the
# browser — so this section is PUBLIC. Never add a secret to that allowlist.
# Empty API URL => relative "/api".
API_URL=
APP_NAME=Bungkit
