{
  "name": "bungkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starterkit: Eleventy (static site) + Angular 22 (SPA) + ElysiaJS (API) on Bun, sharing TailwindCSS v4.",
  "scripts": {
    "dev": "bun run --parallel dev:web dev:css dev:app dev:api",
    "dev:site": "bun run --parallel dev:web dev:css",
    "dev:web": "eleventy --serve",
    "dev:css": "tailwindcss -i apps/website/styles/tailwind.css -o dist/website/assets/styles.css --watch",
    "dev:app": "ng serve",
    "dev:api": "bun --watch apps/backend/src/index.ts",
    "clean": "rm -rf dist .angular",
    "build": "bun run clean && bun run build:website && bun run build:css && bun run build:app && bun run build:backend",
    "build:website": "eleventy",
    "build:css": "tailwindcss -i apps/website/styles/tailwind.css -o dist/website/assets/styles.css --minify",
    "build:app": "ng build",
    "build:backend": "bun build apps/backend/src/index.ts --target bun --outdir dist/backend --minify",
    "start": "bun dist/backend/index.js"
  },
  "dependencies": {
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@elysiajs/static": "^1.4.10",
    "@ojiepermana/angular": "^22.0.46",
    "elysia": "^1.4.29",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
