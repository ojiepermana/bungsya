{
  "name": "bungkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starterkit: Angular 22 (SPA) + ElysiaJS (API) on Bun, with TailwindCSS v4.",
  "scripts": {
    "dev": "bun run --parallel dev:app dev:api",
    "dev:app": "bun run env:generate && ng serve",
    "dev:api": "bun --hot apps/backend/src/main.ts",
    "env:generate": "bun scripts/generate-env.ts",
    "test": "bun test apps/backend",
    "clean": "rm -rf dist .angular",
    "build": "bun run clean && bun run build:app && bun run build:backend",
    "build:app": "bun run env:generate && ng build",
    "build:backend": "bun build apps/backend/src/main.ts --target bun --outdir dist/backend --minify",
    "start": "bun dist/backend/main.js"
  },
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@elysiajs/static": "^1.4.10",
    "@ojiepermana/angular": "^22.0.57",
    "elysia": "^1.4.29",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
